# ── 必須設定 ────────────────────────────────────────────────────────────────────

# Discord Webhook URL（取得成功時に通知を受け取る）
# Discord サーバー → サーバー設定 → 連携サービス → ウェブフック → 新しいウェブフック
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxx/xxxxxxxx

# SSH 公開鍵（作成したインスタンスに SSH 接続するために必要）
# Windows: type %USERPROFILE%\.ssh\id_rsa.pub
# Linux/Mac: cat ~/.ssh/id_rsa.pub
# ない場合: ssh-keygen -t rsa -b 4096
SSH_PUBLIC_KEY=ssh-rsa AAAA...

# ── 省略可能な設定 ──────────────────────────────────────────────────────────────

# 再試行間隔（秒）。デフォルト 300 秒（5分）
# レート制限エラーが頻発する場合は 600〜1800 に増やす
RETRY_INTERVAL_SECONDS=300

# 作成するインスタンスの表示名
INSTANCE_NAME=arm-free-instance

# ── ~/.oci/config を使わず環境変数で認証する場合（上級者向け） ────────────────
# これらをすべて設定した場合、~/.oci/config は不要
# OCI_USER_OCID=ocid1.user.oc1..xxxxxxxxx
# OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
# OCI_TENANCY=ocid1.tenancy.oc1..xxxxxxxxx
# OCI_REGION=ap-tokyo-1
# OCI_KEY_FILE=~/.oci/oci_api_key.pem
# OCI_KEY_CONTENT=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# OCI_KEY_PASSPHRASE=
